    {
      "name": "Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Server response status\", function () {\r",
              "    // Хелперы для читаемости и без спагетти\r",
              "    function isNullOrUndefined(value) {\r",
              "        return value === null || value === undefined;\r",
              "    }\r",
              "\r",
              "    function isEmptyString(value) {\r",
              "        return typeof value === \"string\" && value.trim().length === 0;\r",
              "    }\r",
              "\r",
              "    function isEmptyArray(value) {\r",
              "        return Array.isArray(value) && value.length === 0;\r",
              "    }\r",
              "\r",
              "    if (pm.response.status !== \"OK\") {\r",
              "        throw new Error(JSON.stringify([\"Business Central response status is not 'OK'\"]));\r",
              "    }\r",
              "\r",
              "    const body = pm.response.json();\r",
              "\r",
              "    const statuses = [\"SUCCESS\", \"APPROVED\"];\r",
              "    const currentStatus = body?.status;\r",
              "\r",
              "    if (!Array.isArray(statuses) || !statuses.includes(currentStatus)) {\r",
              "        const errors = [];\r",
              "\r",
              "        const result = body?.result;\r",
              "        if (!isNullOrUndefined(result) && !isEmptyString(result)) {\r",
              "            errors.push(result);\r",
              "        }\r",
              "\r",
              "        const detailedResult = body?.detailedResult;\r",
              "        const detailedInvalid =\r",
              "            isNullOrUndefined(detailedResult) ||\r",
              "            !Array.isArray(detailedResult) ||\r",
              "            isEmptyArray(detailedResult);\r",
              "\r",
              "        if (!detailedInvalid) {\r",
              "            errors.push(detailedResult)\r",
              "        } \r",
              "\r",
              "        // Финальный вброс ошибки\r",
              "        throw new Error(JSON.stringify(errors));\r",
              "    }\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
