    {
      "name": "Deploy",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Server response status\", function () {\r",
              "    if (pm.response.status !== \"Accepted\") {\r",
              "        throw new Error(JSON.stringify([\"Business Central response status is not 'Accepted'\"]));\r",
              "    }\r",
              "\r",
              "    if (pm.response.json().status !== \"APPROVED\") {\r",
              "        throw new Error(JSON.stringify(['Incorrect business central response status']))\r",
              "    }\r",
              "\r",
              "    pm.environment.set(\"deployJobId\", pm.response.json().jobId);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
