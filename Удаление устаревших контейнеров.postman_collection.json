              "\r",
              "pm.test(\"Server response status\", function () {\r",
              "    if (pm.response.status !== \"OK\") {\r",
              "        let msg;\r",
              "        try {\r",
              "            msg = pm.response.json().msg;\r",
              "        } catch (err) {\r",
              "            msg = pm.response.text();\r",
              "        } finally {\r",
              "            throw new Error(JSON.stringify([msg]));\r",
