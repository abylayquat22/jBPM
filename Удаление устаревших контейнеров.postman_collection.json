  "item": [
    {
      "name": "Получение списка контейнеров",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Server response status\", function () {\r",
              "    if (pm.response.status !== \"OK\") {\r",
              "        let msg;\r",
              "        try {\r",
              "            msg = pm.response.json().msg;\r",
              "        } catch (err) {\r",
              "            msg = pm.response.text();\r",
              "        } finally {\r",
              "            throw new Error(JSON.stringify([msg]));\r",
              "        }\r",
              "    }\r",
              "\r",
              "    if (pm.response.json().type !== \"SUCCESS\") {\r",
              "        throw new Error(JSON.stringify([pm.response.json().msg]));\r",
              "    }\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "basic",
          "basic": [
            {
              "key": "password",
              "value": "{{password}}",
              "type": "string"
            },
            {
              "key": "username",
              "value": "{{username}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/kie-server/services/rest/server/containers?artifactId={{artifactId}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "kie-server",
            "services",
            "rest",
            "server",
            "containers"
          ],
          "query": [
            {
              "key": "groupId",
